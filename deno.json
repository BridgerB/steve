{
  "nodeModulesDir": "auto",
  "tasks": {
    "start": "deno run -A main.ts",
    "mcp": "deno run -A --no-check mcp/server.ts",
    "test": "deno test -P --junit-path=test-results.xml",
    "test:parallel": "deno test -P --parallel --junit-path=test-results.xml"
  },
  "test": {
    "permissions": {
      "read": true,
      "write": true,
      "net": true,
      "env": true,
      "sys": true
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@modelcontextprotocol/sdk/server/mcp.js": "npm:@modelcontextprotocol/sdk@latest/server/mcp.js",
    "@modelcontextprotocol/sdk/server/stdio.js": "npm:@modelcontextprotocol/sdk@latest/server/stdio.js",
    "zod": "npm:zod@^3",
    "minecrafthawkeye": "npm:minecrafthawkeye@^1.3.9",
    "mineflayer": "npm:mineflayer@^4.33.0",
    "mineflayer-pathfinder": "npm:mineflayer-pathfinder@^2.4.5",
    "vec3": "npm:vec3@^0.1.10"
  }
}
